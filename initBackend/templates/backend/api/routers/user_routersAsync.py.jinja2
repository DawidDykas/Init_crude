from fastapi import APIRouter, Depends, Query
from api.schemas.user_schemas import *
from api.services.user_servicesAsync import UserServices
from log_config.logger_config import logger
from pydantic import EmailStr
from api.utils.auth_wrapper import get_current_user
from api.modules.database import get_db
from typing import Dict, Any
from sqlalchemy.ext.asyncio import AsyncSession


user_router = APIRouter(
    prefix="/users",
    tags=["Users"]
)


@user_router.post(
    "/create/",
    response_model=UserResponse,
    summary="Create new user",
    description="""
Creates a new user account asynchronously.

Input:
- username: user login name
- email: unique email address
- password: user password

Processing:
- Password is hashed before storing.
- User is saved into database.

Output:
- Created user object:
    - id
    - username
    - email
    - registration date

Possible errors:
- 409: Email already exists
"""
)
async def create_user(
    data: UserCreate,
    session: AsyncSession = Depends(get_db)
):
    """
    Creates a new user in database.
    """
    logger.info("Create user in database")

    return await UserServices.user_create(
        data=data,
        session=session
    )


@user_router.post(
    "/login/",
    response_model=dict[str, Any],
    summary="Authenticate user",
    description="""
Authenticates user using email and password.

Input:
- email: registered user email
- password: account password

Output:
- User information
- JWT access token
- JWT refresh token

Possible errors:
- 401: Invalid credentials
"""
)
async def login_user(
    data: UserLogin,
    session: AsyncSession = Depends(get_db)
):
    """
    Authenticates user and creates JWT tokens.
    """
    logger.info(f"Login user: {data}")

    return await UserServices.login(
        data=data,
        session=session
    )


@user_router.get(
    "/me",
    response_model=UserResponse,
    summary="Get current user profile",
    description="""
Returns information about authenticated user.

Authentication:
- Requires JWT access token in Authorization header.

Input:
- JWT token

Output:
- Current user:
    - id
    - username
    - email
    - registration date

User identity is extracted automatically from token.
"""
)
async def get_current_user_data(
    session: AsyncSession = Depends(get_db),
    current_user: Dict[str, Any] = Depends(get_current_user)
):
    """
    Returns currently logged user data.
    """
    logger.info(
        f"Getting current user data for id: {current_user['id']}"
    )

    data = UserGetById(
        id=current_user["id"]
    )

    return await UserServices.user_get_by_id(
        data=data,
        current_user=current_user,
        session=session
    )


@user_router.post(
    "/refresh",
    summary="Refresh access token",
    description="""
Creates a new access token using refresh token.

Input:
- refresh_token: valid JWT refresh token

Output:
- New access token

Possible errors:
- 401: Invalid refresh token
- 401: Expired refresh token
- 401: Invalid token type
"""
)
async def refresh_token(
    refresh_token: str,
    session: AsyncSession = Depends(get_db)
):
    """
    Generates a new JWT access token.
    """
    logger.info("Refresh access token")

    return await UserServices.refresh_token(
        refresh_token=refresh_token,
        session=session
    )


@user_router.get(
    "/by-email",
    response_model=UserResponse,
    summary="Get user by email",
    description="""
Returns user information based on email.

Authentication:
- Requires valid JWT access token.

Input:
- email: user email address

Output:
- User object:
    - id
    - username
    - email
    - registration date

Security:
- User can only access own account.
"""
)
async def get_user_by_email(
    email: EmailStr = Query(...),
    session: AsyncSession = Depends(get_db),
    current_user: Dict[str, Any] = Depends(get_current_user)
):
    """
    Fetches authenticated user's data by email.
    """
    logger.info(
        f"Getting user with email: {email}"
    )

    data = UserGetByEmail(
        email=email
    )

    return await UserServices.user_get_by_email(
        data=data,
        current_user=current_user,
        session=session
    )


@user_router.post(
    "/update",
    response_model=UserResponse,
    summary="Update user profile",
    description="""
Updates authenticated user information.

Authentication:
- Requires valid JWT access token.

Input:
- Updated user data:
    - username
    - email
    - password

Output:
- Updated user object.

Security:
- User can update only own account.

Possible errors:
- 403: Updating another user's account
- 404: User not found
"""
)
async def user_update(
    data: UserUpdate,
    session: AsyncSession = Depends(get_db),
    current_user: Dict[str, Any] = Depends(get_current_user)
):
    """
    Updates user information asynchronously.
    """
    logger.info(
        f"Update user with email: {data.email}"
    )

    return await UserServices.user_update(
        data=data,
        current_user=current_user,
        session=session
    )


@user_router.delete(
    "/delete",
    response_model=UserResponse,
    summary="Delete user account",
    description="""
Deletes user account permanently.

Authentication:
- Requires valid JWT access token.

Input:
- User ID of account to remove.

Output:
- Deleted user object.

Security:
- User can delete only own account.

Possible errors:
- 403: Deleting another user's account
- 404: User not found
"""
)
async def user_delete(
    data: UserDelete,
    session: AsyncSession = Depends(get_db),
    current_user: Dict[str, Any] = Depends(get_current_user)
):
    """
    Removes authenticated user's account asynchronously.
    """
    logger.info(
        f"Delete user with id: {data.id}"
    )

    return await UserServices.user_delete(
        data=data,
        current_user=current_user,
        session=session
    )