    """
    Flask JWT authentication wrapper.

    Returns:
        JWT payload with user data.

    Raises:
        ServiceException:
            When token is missing or invalid.
    """


    authorization = request.headers.get(
        "Authorization"
    )


    if not authorization or not authorization.startswith(
        "Bearer "
    ):

        logger.warning(
            "Missing or invalid Authorization header"
        )

        raise ServiceException(
            status_code=401,
            detail="Invalid authentication credentials"
        )


    token = authorization.split(
        " ",
        1
    )[1]


    payload = verify_token(
        token
    )


    if not payload:

        logger.warning(
            "Invalid or expired token"
        )


        raise ServiceException(
            status_code=401,
            detail="Invalid or expired token"
        )


    logger.info(
        f"User authenticated: {payload.get('email', 'unknown')}"
    )


    return payload
