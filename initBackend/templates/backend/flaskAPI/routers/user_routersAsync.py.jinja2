from flask import Blueprint, request, jsonify
from {{ api }}API.schemas.user_schemas import *
from {{ api }}API.services.user_servicesAsync import UserServices
from log_config.logger_config import logger
from {{ api }}API.utils.auth_wrapper import get_current_user
from {{ api }}API.modules.database import get_db
from sqlalchemy.ext.asyncio import AsyncSession


user_router = Blueprint(
    "users",
    __name__,
    url_prefix="/users"
)


@user_router.post("/create/")
async def create_user():

    data = UserCreate(**request.json)

    async for session in get_db():

        logger.info("Create user in database")

        result = await UserServices.user_create(
            data,
            session
        )

        return jsonify(
            result.model_dump()
        ), 201



@user_router.post("/login/")
async def login_user():

    data = UserLogin(**request.json)

    async for session in get_db():

        logger.info(f"Login user: {data}")

        token = await UserServices.login(
            data,
            session
        )

        return jsonify(token)



@user_router.post("/refresh")
async def refresh_token():

    refresh_token = request.json.get(
        "refresh_token"
    )

    logger.info("Refresh access token")

    token = UserServices.refresh_token(
        refresh_token
    )

    return jsonify(token)



@user_router.get("/by-id/<int:id>")
async def get_user_by_id(id):

    current_user = get_current_user()

    async for session in get_db():

        logger.info(
            f"Getting user with id: {id}"
        )

        data = UserGetById(
            id=id
        )

        result = await UserServices.user_get_by_id(
            data,
            session
        )

        return jsonify(
            result.model_dump()
        )



@user_router.get("/by-email")
async def get_user_by_email():

    email = request.args.get(
        "email"
    )

    current_user = get_current_user()

    async for session in get_db():

        logger.info(
            f"Getting user with email: {email}"
        )

        data = UserGetByEmail(
            email=email
        )

        result = await UserServices.user_get_by_email(
            data,
            session
        )

        return jsonify(
            result.model_dump()
        )


@user_router.route("/")
def home():
    return {
        "status": "ok",
        "message": "Flask API running"
    }


@user_router.post("/update")
async def user_update():

    data = UserUpdate(**request.json)

    current_user = get_current_user()

    async for session in get_db():

        logger.info(
            f"Update user with email: {data.email}"
        )

        result = await UserServices.user_update(
            data,
            session
        )

        return jsonify(
            result.model_dump()
        )
